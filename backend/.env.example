PROJECT_NAME="CodeBeast"

# Database Configuration (matches docker-compose)
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="codebeast"

# Redis
REDIS_URL="redis://localhost:6379/0"

# --- API KEYS ---
# REQUIRED: Your GitHub Personal Access Token
# This prevents rate-limiting when the Context Builder pulls repository metadata.
GITHUB_TOKEN="your_github_personal_access_token_here"

# REQUIRED LATER: Gemini API Key for the Supervisor agent
GEMINI_API_KEY="your_gemini_api_key_here"
